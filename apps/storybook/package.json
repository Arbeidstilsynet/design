{
  "name": "@arbeidstilsynet/storybook",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter @arbeidstilsynet/design-css dev\" \"pnpm dev:only\"",
    "dev:only": "storybook dev -p 6006",
    "build": "storybook build",
    "test": "vitest run",
    "test:node": "vitest run --project node",
    "test:browser": "vitest run --project storybook-light --project storybook-dark",
    "typecheck": "tsc --noEmit",
    "gen:docgen-wrappers": "tsx utils/generate-docgen-wrappers.ts",
    "lint": "oxlint .",
    "serve": "pnpm dlx http-server ./storybook-static",
    "circular": "pnpm dlx madge --circular --extensions \"js,jsx,ts,tsx\" ./stories"
  },
  "dependencies": {
    "@arbeidstilsynet/design-css": "workspace:*",
    "@arbeidstilsynet/design-react": "workspace:*",
    "@arbeidstilsynet/design-theme": "workspace:*",
    "@navikt/aksel-icons": "8.15.0",
    "clsx": "2.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-toastify": "^11.1.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "10.5.2",
    "@storybook/addon-docs": "10.5.2",
    "@storybook/addon-vitest": "10.5.2",
    "@storybook/react-vite": "10.5.2",
    "@testing-library/dom": "10.4.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "concurrently": "10.0.3",
    "eslint-plugin-storybook": "10.5.2",
    "playwright": "1.61.1",
    "storybook": "10.5.2",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
