{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@arbeidstilsynet/design-react": ["./docgen-wrappers/index.tsx"]
    },

    "verbatimModuleSyntax": false, // too much hassle to fix type imports in the upstream stories right now
    "exactOptionalPropertyTypes": false // annoying in some upstream stories for data-[size/color]
  },
  "include": [
    ".storybook/**/*",
    "docgen-wrappers/**/*",
    "stories/**/*",
    "utils/**/*",
    "*.ts",
    "*.mjs",
    "global.d.ts",
    "../../packages/react/src/**/*"
  ]
}
