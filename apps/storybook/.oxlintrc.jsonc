{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "extends": ["../../.oxlintrc.jsonc"],
  "plugins": ["react", "jsx-a11y"],
  "jsPlugins": [
    {
      "name": "storybook",
      "specifier": "eslint-plugin-storybook",
    },
  ],
  "rules": {
    "storybook/await-interactions": "error",
  },
}
