{
  "name": "root",
  "private": true,
  "type": "module",
  "scripts": {
    "tokens:create": "pnpm designsystemet tokens create --clean",
    "tokens:build": "pnpm designsystemet tokens build --clean -o ./packages/theme/brand",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc -b",
    "typecheck:scripts": "tsc --project scripts",
    "lint": "pnpm -r lint",
    "dev": "pnpm storybook",
    "test": "vitest run",
    "build": "pnpm -r build",
    "build:react": "pnpm --filter @arbeidstilsynet/design-react build",
    "build:storybook": "pnpm --filter storybook... build",
    "version": "tsx scripts/filter-renovate-changesets.ts && changeset version && tsx scripts/add-changelog-date.ts && tsx scripts/dedupe-changelog.ts",
    "release": "pnpm build && changeset publish",
    "storybook": "pnpm --filter storybook dev",
    "storybook:serve": "pnpm --filter storybook serve"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@digdir/designsystemet": "1.13.3",
    "@svitejs/changesets-changelog-github-compact": "1.2.0",
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "4.1.5",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.22.0",
    "prettier": "3.8.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@11.0.0-rc.5"
}
