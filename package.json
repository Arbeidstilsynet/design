{
  "name": "root",
  "private": true,
  "type": "module",
  "scripts": {
    "tokens:create": "pnpm designsystemet tokens create --clean",
    "tokens:build": "pnpm designsystemet tokens build --clean -o ./packages/theme/brand",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc -b",
    "typecheck:scripts": "tsc --project scripts",
    "lint": "oxlint .",
    "dev": "pnpm storybook",
    "test": "vitest run",
    "build": "pnpm -r build",
    "build:react": "pnpm --filter @arbeidstilsynet/design-react build",
    "build:storybook": "pnpm --filter storybook... build",
    "version": "changeset version && tsx scripts/postprocess-changelogs.ts",
    "release": "pnpm build && changeset publish",
    "storybook": "pnpm --filter storybook dev",
    "storybook:serve": "pnpm --filter storybook serve"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@changesets/get-github-info": "0.8.0",
    "@changesets/types": "6.1.0",
    "@digdir/designsystemet": "1.13.3",
    "@scaleway/changesets-renovate": "3.0.2",
    "@types/node": "24.12.4",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "workspace:*",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "oxlint-tsgolint": "0.23.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485"
}
