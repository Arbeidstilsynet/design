{
  "name": "root",
  "private": true,
  "type": "module",
  "scripts": {
    "tokens:create": "pnpm designsystemet tokens create --clean",
    "tokens:build": "pnpm designsystemet tokens build --clean -o ./packages/theme/brand",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc -b",
    "typecheck:scripts": "tsc --project scripts",
    "lint": "oxlint .",
    "dev": "pnpm storybook",
    "test": "vitest run",
    "build": "pnpm -r build",
    "build:react": "pnpm --filter @arbeidstilsynet/design-react build",
    "build:storybook": "pnpm --filter storybook... build",
    "version": "changeset version && tsx scripts/add-changelog-date.ts && tsx scripts/dedupe-changelog.ts",
    "release": "pnpm build && changeset publish",
    "storybook": "pnpm --filter storybook dev",
    "storybook:serve": "pnpm --filter storybook serve"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@digdir/designsystemet": "1.13.3",
    "@scaleway/changesets-renovate": "3.0.2",
    "@svitejs/changesets-changelog-github-compact": "1.2.0",
    "@types/node": "24.12.4",
    "@vitest/coverage-v8": "4.1.7",
    "eslint": "workspace:*",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "oxlint-tsgolint": "0.23.0",
    "tsx": "4.22.2",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f"
}
