{
  "name": "root",
  "private": true,
  "type": "module",
  "scripts": {
    "tokens:create": "pnpm designsystemet tokens create --clean",
    "tokens:build": "pnpm designsystemet tokens build --clean -o ./packages/theme/brand",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc -b",
    "typecheck:scripts": "tsc --project scripts",
    "lint": "oxlint .",
    "dev": "pnpm storybook",
    "test": "vitest run",
    "build": "pnpm -r build",
    "build:react": "pnpm --filter @arbeidstilsynet/design-react build",
    "build:storybook": "pnpm --filter storybook... build",
    "version": "changeset version && tsx scripts/postprocess-changelogs.ts",
    "release": "pnpm build && changeset publish",
    "storybook": "pnpm --filter storybook dev",
    "storybook:serve": "pnpm --filter storybook serve"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@changesets/get-github-info": "0.8.0",
    "@changesets/types": "6.1.0",
    "@digdir/designsystemet": "1.16.1",
    "@scaleway/changesets-renovate": "3.0.3",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "workspace:*",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
