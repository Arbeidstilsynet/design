{
  "name": "@arbeidstilsynet/design-react",
  "version": "0.11.1",
  "description": "React implementation of Designsystemet",
  "license": "MIT",
  "author": "Arbeidstilsynet",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arbeidstilsynet/design.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
