{
  "name": "@arbeidstilsynet/design-css",
  "version": "0.10.5",
  "description": "CSS for Designsystemet",
  "license": "MIT",
  "author": "Arbeidstilsynet",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arbeidstilsynet/design.git"
  },
  "files": [
    "./types.d.ts",
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./types.d.ts",
      "default": "./dist/src/index.css"
    },
    "./digdir/*": "./dist/digdir/*",
    "./*": "./dist/src/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "postcss ./src/*.css --base . --dir ./dist --watch",
    "build": "del-cli ./dist && postcss ./src/*.css --base . --dir ./dist && tsx ./scripts/copy-digdir-css.ts"
  },
  "dependencies": {
    "@digdir/designsystemet-css": "1.13.3"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "autoprefixer": "10.5.0",
    "cssnano": "7.1.8",
    "del-cli": "7.0.0",
    "postcss": "8.5.13",
    "postcss-cli": "11.0.1",
    "postcss-import": "16.1.1",
    "postcss-nesting": "14.0.0",
    "tsx": "4.21.0"
  }
}
